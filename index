  <script>
    function updateClock() {
      const now = new Date();

      const options = {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        weekday: "long",
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit"
      };

      document.getElementById("clock").textContent =
        "現在時間：" + now.toLocaleString("zh-TW", options);
    }

    updateClock();
    setInterval(updateClock, 1000);
