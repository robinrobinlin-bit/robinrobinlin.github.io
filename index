<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Robin Lin | Personal Page</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: "Segoe UI", "Noto Sans TC", sans-serif;
    }

    body {
      min-height: 100vh;
      background: radial-gradient(circle at top, #102a43, #020617 70%);
      color: white;
      overflow-x: hidden;
    }

    .stars {
      position: fixed;
      width: 100%;
      height: 100%;
      background-image:
        radial-gradient(white 1px, transparent 1px),
        radial-gradient(#38bdf8 1px, transparent 1px);
      background-size: 80px 80px, 120px 120px;
      animation: moveStars 30s linear infinite;
      opacity: 0.35;
      z-index: -1;
    }

    @keyframes moveStars {
      from {
        background-position: 0 0, 0 0;
      }
      to {
        background-position: 1000px 500px, 600px 900px;
      }
    }

    header {
      padding: 24px 8%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      backdrop-filter: blur(12px);
    }

    .logo {
      font-size: 24px;
      font-weight: 800;
      background: linear-gradient(90deg, #38bdf8, #22c55e, #a855f7);
      -webkit-background-clip: text;
      color: transparent;
    }

    nav a {
      color: #cbd5e1;
      margin-left: 24px;
      text-decoration: none;
      font-size: 15px;
    }

    nav a:hover {
      color: #38bdf8;
    }

    .hero {
      min-height: 85vh;
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      align-items: center;
      gap: 40px;
      padding: 40px 8%;
    }

    .hero h1 {
      font-size: clamp(42px, 7vw, 86px);
      line-height: 1.1;
      margin-bottom: 24px;
    }

    .gradient-text {
      background: linear-gradient(90deg, #38bdf8, #22c55e, #facc15);
      -webkit-background-clip: text;
      color: transparent;
    }

    .hero p {
      font-size: 20px;
      color: #cbd5e1;
      line-height: 1.8;
      margin-bottom: 30px;
    }

    .buttons a {
      display: inline-block;
      padding: 14px 24px;
      border-radius: 999px;
      margin-right: 12px;
      text-decoration: none;
      font-weight: 700;
    }

    .primary {
      background: linear-gradient(90deg, #38bdf8, #22c55e);
      color: #020617;
    }

    .secondary {
      border: 1px solid #38bdf8;
      color: #38bdf8;
    }

    .card {
      background: rgba(15, 23, 42, 0.75);
      border: 1px solid rgba(56, 189, 248, 0.35);
      border-radius: 28px;
      padding: 32px;
      box-shadow: 0 0 40px rgba(56, 189, 248, 0.18);
      backdrop-filter: blur(16px);
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-8px);
      box-shadow: 0 0 60px rgba(56, 189, 248, 0.35);
    }

    .profile-title {
      color: #38bdf8;
      margin-bottom: 16px;
      font-size: 22px;
    }

    .profile-list {
      list-style: none;
      color: #cbd5e1;
      line-height: 2;
    }

    section {
      padding: 70px 8%;
    }

    section h2 {
      text-align: center;
      font-size: 38px;
      margin-bottom: 40px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .project-card {
      background: rgba(15, 23, 42, 0.7);
      border: 1px solid rgba(148, 163, 184, 0.25);
      border-radius: 24px;
      padding: 26px;
      transition: 0.3s;
    }

    .project-card:hover {
      transform: translateY(-6px);
      border-color: #38bdf8;
    }

    .project-card h3 {
      color: #38bdf8;
      margin-bottom: 12px;
    }

    .project-card p {
      color: #cbd5e1;
      line-height: 1.7;
    }

    .tag {
      display: inline-block;
      margin-top: 16px;
      padding: 6px 12px;
      background: rgba(56, 189, 248, 0.15);
      border-radius: 999px;
      color: #7dd3fc;
      font-size: 13px;
    }

    footer {
      text-align: center;
      padding: 40px;
      color: #94a3b8;
      border-top: 1px solid rgba(148, 163, 184, 0.2);
    }

    #clock {
      margin-top: 20px;
      color: #facc15;
      font-weight: 700;
    }

    @media (max-width: 900px) {
      .hero {
        grid-template-columns: 1fr;
      }

      .grid {
        grid-template-columns: 1fr;
      }

      nav {
        display: none;
      }
    }
  </style>
</head>

